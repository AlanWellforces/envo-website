# Copy this file to .env.local and fill in your values
# Never commit .env.local to git

# Database
# Local Docker:  postgresql://envo:envo_dev_password@localhost:5432/envo_dev
# NAS:           postgresql://envo:<password>@192.168.68.80:5432/envo_dev
# Supabase:      postgresql://postgres:<password>@<project>.supabase.co:5432/postgres
DATABASE_URL=postgresql://envo:envo_dev_password@localhost:5432/envo_dev

# Payload CMS — generate a random 32-char string
PAYLOAD_SECRET=

# Akeneo PIM
AKENEO_URL=https://pim.wellforces.com
AKENEO_CLIENT_ID=
AKENEO_CLIENT_SECRET=
AKENEO_USERNAME=
AKENEO_PASSWORD=

# Anthropic (for Find Your Match AI)
ANTHROPIC_API_KEY=

# Resend (for enquiry form emails)
RESEND_API_KEY=

# Cloudflare R2 (for product images)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
