# Copy this file to .env.local and fill in your values
# Never commit .env.local to git

# Database
#
# Team default: Supabase free tier via Session Pooler (us-west-2).
# Connection string is in Zoho Vault: "ENVO Dev Database — Supabase".
# See notes/2026-05-15-dev-db-supabase.md for architecture details.
#
# Expected formats:
#   Supabase Session Pooler (team default — port 5432, IPv4-proxied):
#     postgresql://postgres.<project-ref>:<password>@aws-1-us-west-2.pooler.supabase.com:5432/postgres
#   Supabase Transaction Pooler (for serverless / Vercel later — port 6543):
#     postgresql://postgres.<project-ref>:<password>@aws-1-us-west-2.pooler.supabase.com:6543/postgres
#   Local Docker (offline / individual dev):
#     postgresql://envo:envo_dev_password@localhost:5432/envo_dev
#
DATABASE_URL=

# Payload CMS — generate a random 32-char string
PAYLOAD_SECRET=

# Akeneo PIM
AKENEO_URL=https://pim.wellforces.com
AKENEO_CLIENT_ID=
AKENEO_CLIENT_SECRET=
AKENEO_USERNAME=
AKENEO_PASSWORD=
# Webhook secret — copy from Akeneo PIM > Connections > Webhooks > <your webhook> > Secret
# Leave unset to skip signature verification (safe for local dev, required in production)
AKENEO_WEBHOOK_SECRET=

# Anthropic — optional. Enables the AI-written rationale on /find-your-match;
# the tool falls back to a template paragraph if this is unset.
ANTHROPIC_API_KEY=

# Resend (for enquiry form emails)
RESEND_API_KEY=

# Supabase Storage (S3-compatible) — file binaries for Media uploads.
# Bucket + keys from Supabase dashboard → Storage → S3 connection. Secrets in Zoho Vault.
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=us-west-2
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Separate PRIVATE bucket for lead-files (customer-submitted PII sketches) —
# never publicly readable; Payload proxies reads behind staff login.
# Leave blank to keep lead-files on local disk.
S3_LEAD_FILES_BUCKET=

# Cloudflare R2 (for product images)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Optional dedicated salt for the cookieless analytics sessionHash.
# Falls back to PAYLOAD_SECRET when unset.
ANALYTICS_SALT=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Blog — shared secret for the /api/revalidate endpoint (called by Payload
# afterChange hooks to invalidate Next.js ISR cache). Generate a random string.
REVALIDATE_SECRET=
