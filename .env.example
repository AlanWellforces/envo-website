# Copy this file to .env.local and fill in your values
# Never commit .env.local to git

# Database — local Docker Postgres (Supabase is retired; see DEPLOY.md).
# Bring it up with `docker compose up -d` (isolated Postgres 17 on your laptop),
# then load real data with `./scripts/db-refresh-from-prod.sh`. The default below
# matches docker-compose.yml, so copying this file as-is Just Works locally.
#
#   Local Docker (the default now — host port 5433):
#     postgresql://envo:envo_dev_password@localhost:5433/envo_dev
#
DATABASE_URL=postgresql://envo:envo_dev_password@localhost:5433/envo_dev

# Payload CMS — generate a random 32-char string
PAYLOAD_SECRET=

# Payload schema auto-push — DEV ONLY. When "true", `next dev` syncs local
# schema changes straight to your local DB, no migration needed (fast iteration).
# IGNORED in production: the postgres adapter only pushes when NODE_ENV !=
# production, so setting this on the box does nothing. Prod schema changes go
# through migrations — see DEPLOY.md § "Schema changes".
PAYLOAD_DB_PUSH=true

# Akeneo PIM
AKENEO_URL=https://pim.wellforces.com
AKENEO_CLIENT_ID=
AKENEO_CLIENT_SECRET=
AKENEO_USERNAME=
AKENEO_PASSWORD=
# Webhook secret — copy from Akeneo PIM > Connections > Webhooks > <your webhook> > Secret
# Leave unset to skip signature verification (safe for local dev, required in production)
AKENEO_WEBHOOK_SECRET=

# Anthropic — optional. Enables the AI-written rationale on /find-your-match;
# the tool falls back to a template paragraph if this is unset.
ANTHROPIC_API_KEY=

# Resend (for enquiry form emails)
RESEND_API_KEY=

# Supabase Storage (S3-compatible) — file binaries for Media uploads.
# Bucket + keys from Supabase dashboard → Storage → S3 connection. Secrets in Zoho Vault.
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=us-west-2
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Separate PRIVATE bucket for lead-files (customer-submitted PII sketches) —
# never publicly readable; Payload proxies reads behind staff login.
# Leave blank to keep lead-files on local disk.
S3_LEAD_FILES_BUCKET=

# Cloudflare R2 (for product images)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Optional dedicated salt for the cookieless analytics sessionHash.
# Falls back to PAYLOAD_SECRET when unset.
ANALYTICS_SALT=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Blog — shared secret for the /api/revalidate endpoint (called by Payload
# afterChange hooks to invalidate Next.js ISR cache). Generate a random string.
REVALIDATE_SECRET=

# Daily "unhandled leads" reminder — shared secret for GET /api/leads-digest
# (hit by a timer on the box, see DEPLOY.md). Blank = endpoint off (404).
LEADS_DIGEST_SECRET=

# Cloudflare Turnstile — bot check on the upload-bearing Free Layout form.
# Leave BOTH blank to disable (local dev): no widget renders, the API skips
# verification. Create the widget in the Cloudflare dashboard → Turnstile.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
